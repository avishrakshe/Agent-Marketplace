# Orchestrator Production Environment Variables
# Copy this file to services/orchestrator/.env and fill in your values

# ===== BLOCKCHAIN CONFIGURATION =====
# RPC Endpoint for Avalanche C-Chain (testnet or mainnet)
# Testnet: https://api.avax-testnet.network/ext/bc/C/rpc
# Mainnet: https://api.avax.network/ext/bc/C/rpc
RPC_URL=https://api.avax-testnet.network/ext/bc/C/rpc

# Chain ID
# Testnet (Fuji): 43113
# Mainnet: 43114
# Local devnet: 99999
CHAIN_ID=43113

# ===== WALLET CONFIGURATION =====
# Orchestrator wallet private key (hex-encoded with 0x prefix)
# This wallet must have tUSDC balance for payments
# IMPORTANT: Store this as a platform secret, not in version control!
ORCHESTRATOR_PRIVATE_KEY=0x...

# ===== PAYMENT SETTINGS =====
# Minimum reputation score required for agents (default: 50)
MIN_REPUTATION_SCORE=50

# Maximum amount of USDC to spend per session (default: 1.0)
SESSION_SPEND_CAP=1.0

# ===== SPECIALIST SERVICE URLS =====
# If running specialist agents on separate servers, provide their URLs
# Otherwise, the orchestrator will try to connect to localhost
SUMMARIZER_URL=http://localhost:4001
TRANSLATOR_URL=http://localhost:4002
AUDITOR_URL=http://localhost:4003
GAS_TIMING_URL=http://localhost:4004
RISK_SCORER_URL=http://localhost:4005

# ===== OPTIONAL: DEPLOYMENT-SPECIFIC =====
# API Port (default: 5000)
PORT=5000

# CORS origins (comma-separated; default: *)
CORS_ORIGINS=*

# Enable debug logging
DEBUG=false

# ===== SMART CONTRACTS =====
# Note: Contract addresses and ABIs are loaded from shared/deployed.json
# Make sure deployed.json is properly populated before starting the orchestrator
