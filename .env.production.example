# =============================================================================
# PRODUCTION DEPLOYMENT — copy to platform env vars (never commit real keys)
# =============================================================================

# --- Blockchain (Avalanche Fuji recommended for public demo) ---
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CHAIN_ID=43113

# --- Backend URLs (set after deploying orchestrator + agents) ---
ORCHESTRATOR_URL=https://your-orchestrator.up.railway.app
NEXT_PUBLIC_ORCHESTRATOR_URL=https://your-orchestrator.up.railway.app

# --- Wallets (generate fresh keys for production; fund with Fuji AVAX + tUSDC) ---
DEV_PRIVATE_KEY=0x...
ORCHESTRATOR_PRIVATE_KEY=0x...
AGENT_AUDITOR_PRIVATE_KEY=0x...
AGENT_RISK_SCORER_PRIVATE_KEY=0x...
AGENT_GAS_TIMING_PRIVATE_KEY=0x...

# --- WalletConnect (required for RainbowKit in production) ---
# Create free project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# --- Optional ---
OPENAI_API_KEY=
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
SESSION_SPEND_CAP=1.0
MIN_REPUTATION_SCORE=50
